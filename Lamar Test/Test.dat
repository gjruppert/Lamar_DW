SQL Scripts

 SELECT 
  CO.COMPANY_LVL7_DESC AS COMPANY_LVL7_DESC,
 C.YEAR_NUMBER AS YEAR_NUMBER,
 SUM(F.AMOUNT_LOCAL) AS AMOUNT_LOCAL

 FROM svo.F_GL_LINES F
 INNER JOIN svo.D_CALENDAR C ON (F.EFFECTIVE_DATE_SK = C.DATE_SK) and C.[YEAR_NUMBER] =  2025 and C.[PERIOD_NUMBER] = 7
 INNER JOIN svo.D_COMPANY CO ON (F.COMPANY_SK = CO.COMPANY_SK) and CO.[COMPANY_LVL7_CODE] = 1062
 INNER JOIN svo.D_ACCOUNT A ON  F.ACCOUNT_SK = A.ACCOUNT_SK and [ACCOUNT_LVL5_CODE] = 'OPEXP'
 GROUP BY COMPANY_LVL7_DESC, C.YEAR_NUMBER
 order by 1,2
 
 OUTPUT:
 COMPANY_LVL7_DESC	YEAR_NUMBER	AMOUNT_LOCAL
Alexandria, LA	2025	161536.01